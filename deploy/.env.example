
# --- Clé API OpenWeather (secret) ---
OPENWEATHER_API_KEY=

# --- Airflow : UID pour éviter les problèmes de permissions sur les volumes ---
# Sur le serveur : echo $(id -u)
AIRFLOW_UID=50000

# --- Airflow : base de métadonnées (interne, jamais exposée à IA1) ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=
AIRFLOW_DB_NAME=airflow

# --- Airflow : compte admin de l'UI web (port 8080) ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=

# --- Data Warehouse air_quality : utilisateur de chargement (droits complets) ---
DWH_DB_NAME=air_quality
DWH_DB_USER=air_quality_loader
DWH_DB_PASSWORD=

# --- Data Warehouse air_quality : utilisateur lecture seule (à donner à IA1) ---
READONLY_DB_USER=air_quality_readonly
READONLY_DB_PASSWORD=
